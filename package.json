{
  "name": "dna-sequence-workbench",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,api -c green,magenta \"vite\" \"tsx watch api/index.ts\"",
    "dev:client": "vite",
    "dev:api": "tsx watch api/index.ts",
    "build": "tsc -b && vite build",
    "build:client": "vite build",
    "build:api": "tsc -p tsconfig.api.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx tests/**/*.test.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
